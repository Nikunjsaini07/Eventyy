{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm run vercel:install",
  "buildCommand": "npm run vercel:build",
  "functions": {
    "api/v1/[...all].ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
