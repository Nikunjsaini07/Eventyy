{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm run vercel:install",
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
