datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  COORDINATOR
  STUDENT
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
}

enum GameType {
  INDIVIDUAL
  TEAM
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  rollNumber         String?             @unique @map("roll_number")
  name               String
  email              String              @unique
  passwordHash       String              @map("password_hash")
  role               Role
  department         String?
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  createdEvents      Event[]             @relation("event_creator")
  coordinatedEvents  EventCoordinator[]
  participants       Participant[]
  winners            Winner[]
  leaderboard        Leaderboard?
  refreshTokens      RefreshToken[]

  @@index([role])
  @@index([department])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Event {
  id           String             @id @default(uuid()) @db.Uuid
  name         String
  description  String
  bannerImage  String?            @map("banner_image")
  startDate    DateTime           @map("start_date")
  endDate      DateTime           @map("end_date")
  venue        String
  createdBy    String             @map("created_by") @db.Uuid
  status       EventStatus        @default(UPCOMING)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  creator      User               @relation("event_creator", fields: [createdBy], references: [id], onDelete: Restrict)
  coordinators EventCoordinator[]
  games        Game[]

  @@index([status])
  @@index([createdBy])
  @@index([startDate, endDate])
  @@map("events")
}

model EventCoordinator {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  coordinatorId String   @map("coordinator_id") @db.Uuid
  assignedAt    DateTime @default(now()) @map("assigned_at")

  event       Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  coordinator User  @relation(fields: [coordinatorId], references: [id], onDelete: Cascade)

  @@unique([eventId, coordinatorId])
  @@index([coordinatorId])
  @@map("event_coordinators")
}

model Game {
  id              String         @id @default(uuid()) @db.Uuid
  eventId         String         @map("event_id") @db.Uuid
  name            String
  rules           String?
  maxParticipants Int            @map("max_participants")
  gameType        GameType       @map("game_type")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teams        Team[]
  participants Participant[]
  matches      Match[]
  winners      Winner[]

  @@unique([eventId, name])
  @@index([eventId])
  @@map("games")
}

model Team {
  id        String        @id @default(uuid()) @db.Uuid
  gameId    String        @map("game_id") @db.Uuid
  teamName  String        @map("team_name")
  createdAt DateTime      @default(now()) @map("created_at")

  game         Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  participants Participant[]

  @@unique([gameId, teamName])
  @@index([gameId])
  @@map("teams")
}

model Participant {
  id           String    @id @default(uuid()) @db.Uuid
  gameId        String    @map("game_id") @db.Uuid
  studentId     String    @map("student_id") @db.Uuid
  teamId        String?   @map("team_id") @db.Uuid
  registeredAt  DateTime  @default(now()) @map("registered_at")

  game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  student  User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  team     Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  match1   Match[] @relation("match_participant1")
  match2   Match[] @relation("match_participant2")
  wins     Match[] @relation("match_winner")

  @@unique([gameId, studentId])
  @@index([studentId])
  @@index([teamId])
  @@map("participants")
}

model Match {
  id             String   @id @default(uuid()) @db.Uuid
  gameId         String   @map("game_id") @db.Uuid
  roundNumber    Int      @map("round_number")
  participant1Id String   @map("participant1_id") @db.Uuid
  participant2Id String   @map("participant2_id") @db.Uuid
  winnerId       String?  @map("winner_id") @db.Uuid
  scoreData      Json?    @map("score_data")
  createdAt      DateTime @default(now()) @map("created_at")

  game         Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  participant1 Participant @relation("match_participant1", fields: [participant1Id], references: [id], onDelete: Restrict)
  participant2 Participant @relation("match_participant2", fields: [participant2Id], references: [id], onDelete: Restrict)
  winner       Participant? @relation("match_winner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([gameId, roundNumber])
  @@index([winnerId])
  @@map("matches")
}

model Winner {
  id         String   @id @default(uuid()) @db.Uuid
  gameId     String   @map("game_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  position   String
  year       Int
  createdAt  DateTime @default(now()) @map("created_at")

  game    Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([gameId, position, year])
  @@index([year])
  @@index([studentId])
  @@map("winners")
}

model Leaderboard {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @unique @map("student_id") @db.Uuid
  totalPoints Int      @default(0) @map("total_points")
  lastUpdated DateTime @updatedAt @map("last_updated")

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([totalPoints])
  @@map("leaderboard")
}
